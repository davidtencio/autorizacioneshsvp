rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isReadOnlyUser() {
      return isSignedIn()
        && request.auth.token.email in [
          'fhsvp2208@gmail.com'
        ];
    }

    function hasUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Hybrid permission:
    //  - If users/{uid} exists, role must be 'admin' or 'editor'.
    //  - If users/{uid} does NOT exist, fall back to legacy logic
    //    (signed-in, non-anonymous, not in read-only whitelist).
    // The fallback will be removed once all current editors are seeded.
    function canWrite() {
      return isSignedIn() && !isAnonymous() && (
        (hasUserDoc() && userRole() in ['admin', 'editor'])
        || (!hasUserDoc() && !isReadOnlyUser())
      );
    }

    function validMedicationCategory(value) {
      return value == 'Almacenable'
        || value == 'Compra Local'
        || value == 'No Definido';
    }

    function validString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function validOptionalString(value, maxLen) {
      return value == null || (value is string && value.size() <= maxLen);
    }

    function validPatientStatus(value) {
      return value == null || value == 'Active' || value == 'Suspended';
    }

    function validIssuer(value) {
      return value is string && value in ['CCF', 'CLF', 'RA'];
    }

    function validPatientsSummary(value) {
      return value is map
        && value.keys().hasOnly(['count', 'lastUpdated'])
        && value.keys().hasAll(['count', 'lastUpdated'])
        // Note: Firebase Web SDK serializes JS Numbers as Double, even when
        // they are integer values. Using `is number` (accepts int and float)
        // instead of `is int` to allow updates from the client.
        && value.count is number
        && value.count >= 0
        && value.lastUpdated is string
        && value.lastUpdated.size() <= 40;
    }

    function isMedicationDocument(data) {
      return data.keys().hasAll(['code', 'name', 'strength', 'route', 'type', 'patientsSummary'])
        && data.keys().hasOnly(['code', 'name', 'strength', 'route', 'type', 'category', 'patientsSummary', 'patientsSummaryMigratedAt'])
        && validString(data.code, 40)
        && validString(data.name, 200)
        && validString(data.strength, 80)
        && validString(data.route, 80)
        && validString(data.type, 60)
        && validPatientsSummary(data.patientsSummary)
        && (
          !data.keys().hasAny(['category'])
          || (data.category is string && validMedicationCategory(data.category))
        );
    }

    function isPrescriberDocument(data) {
      return data.keys().hasAll(['name', 'specialty'])
        && data.keys().hasOnly(['name', 'specialty'])
        && validString(data.name, 120)
        && validString(data.specialty, 120);
    }

    function isTransferControl(data) {
      return data == null
        || (
          data is map
          && data.keys().hasOnly(['sentDate', 'receivedDate', 'notes', 'totalUnits', 'transfers', 'pendingBalance'])
          && (!data.keys().hasAny(['sentDate']) || validOptionalString(data.sentDate, 40))
          && (!data.keys().hasAny(['receivedDate']) || validOptionalString(data.receivedDate, 40))
          && (!data.keys().hasAny(['notes']) || validOptionalString(data.notes, 500))
          && (!data.keys().hasAny(['totalUnits']) || validOptionalString(data.totalUnits, 40))
          && (!data.keys().hasAny(['pendingBalance']) || validOptionalString(data.pendingBalance, 40))
          && (
            !data.keys().hasAny(['transfers'])
            || (
              data.transfers is list
              && data.transfers.size() <= 100
            )
          )
        );
    }

    function isPatientDocument(data) {
      return data.keys().hasAll([
        'id',
        'identificationNumber',
        'name',
        'diagnosis',
        'authorizationCode',
        'issuer',
        'startMonth',
        'endMonth',
        'dose',
        'frequency',
        'route',
        'totalCycles',
        'totalMonths',
        'applicationPlace',
        'prescriber',
        'specialty'
      ])
      && data.keys().hasOnly([
        'id',
        'identificationNumber',
        'name',
        'diagnosis',
        'authorizationCode',
        'issuer',
        'startMonth',
        'endMonth',
        'dose',
        'frequency',
        'route',
        'totalCycles',
        'totalMonths',
        'applicationPlace',
        'prescriber',
        'specialty',
        'transferControl',
        'status',
        'suspensionReason',
        'suspensionNotes',
        'suspensionDate',
        'authorizationHistory'
      ])
      && data.id is int
      && validString(data.identificationNumber, 40)
      && validString(data.name, 180)
      && validString(data.diagnosis, 300)
      && validString(data.authorizationCode, 80)
      && validIssuer(data.issuer)
      && validString(data.startMonth, 20)
      && validString(data.endMonth, 20)
      && validString(data.dose, 120)
      && validString(data.frequency, 120)
      && validString(data.route, 80)
      && validString(data.totalCycles, 40)
      && validString(data.totalMonths, 40)
      && validString(data.applicationPlace, 120)
      && validString(data.prescriber, 180)
      && validString(data.specialty, 120)
      && (!data.keys().hasAny(['status']) || validPatientStatus(data.status))
      && (!data.keys().hasAny(['suspensionReason']) || validOptionalString(data.suspensionReason, 120))
      && (!data.keys().hasAny(['suspensionNotes']) || validOptionalString(data.suspensionNotes, 500))
      && (!data.keys().hasAny(['suspensionDate']) || validOptionalString(data.suspensionDate, 40))
      && (!data.keys().hasAny(['transferControl']) || isTransferControl(data.transferControl));
    }

    match /medications/{medicationId} {
      allow read: if isSignedIn();
      allow create, update: if canWrite() && isMedicationDocument(request.resource.data);
      allow delete: if canWrite();
    }

    match /medications/{medicationId}/patients/{patientId} {
      allow read: if isSignedIn();
      allow create, update: if canWrite() && isPatientDocument(request.resource.data);
      allow delete: if canWrite();
    }

    match /prescribers/{prescriberId} {
      allow read: if isSignedIn();
      allow create, update: if canWrite() && isPrescriberDocument(request.resource.data);
      allow delete: if canWrite();
    }

    match /users/{userId} {
      // Each user can read only their own role doc.
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Writes are managed by the seed script using a service account
      // (which bypasses rules). Clients cannot create/update/delete roles.
      allow write: if false;
    }

    function isValidOpsLogPayload(data) {
      return data.keys().hasAll(['ts', 'level', 'message'])
        && data.keys().hasOnly(['ts', 'level', 'message', 'meta'])
        && data.level in ['info', 'warn', 'error']
        && data.message is string
        && data.message.size() > 0
        && data.message.size() <= 500
        && data.ts is string
        && data.ts.size() <= 40
        && (!data.keys().hasAny(['meta']) || data.meta is map);
    }

    match /ops_logs/{logId} {
      // Any signed-in non-anonymous user can append a log entry, but the
      // payload must conform to the schema (capped fields + size).
      allow create: if isSignedIn()
        && !isAnonymous()
        && isValidOpsLogPayload(request.resource.data);
      allow read, update, delete: if false;
    }

    // Catch-all: deny access to any collection not explicitly matched above.
    // Note: in Firestore rules, allow conditions across matching rules are OR'd.
    // Keeping this strict (deny by default) ensures unlisted collections — and
    // sensitive docs like users/{uid} — are not exposed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
