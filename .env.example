# Firebase Web SDK config (per environment).
# Copy to .env.development or .env.production and fill in the values
# for the target Firebase project. If a variable is unset, the app
# falls back to the hardcoded production defaults in src/firebase/app.ts
# (legacy behavior).
#
# Notes:
# - These are NOT secrets — Firebase Web API keys are public by design.
# - Access is restricted by Firestore rules and Auth, not by the key.

VITE_FB_PROJECT_ID=
VITE_FB_APP_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_MEASUREMENT_ID=
