{
  "name": "hsvp-autorizaciones",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "migrate:patients:backfill": "node scripts/migrations/backfill-patients-subcollection-admin.mjs",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "smoke": "node scripts/smoke-check.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run --dir src",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config firestore-rules-tests/vitest.rules.config.ts firestore-rules-tests/firestore.rules.test.ts\"",
    "quality:baseline": "npm run lint && npm run test -- --run && npm run build && npm run bundle:check && npm run smoke"
  },
  "dependencies": {
    "firebase": "^12.8.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.30.3",
    "react-virtuoso": "^4.18.1",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.18.0",
    "globals": "^16.5.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
